// 会計開始（checkout）処理

#include <stdio.h>
#include <math.h> // floor関数を使う

// --（ここはみんなで共有するCartItemなどを使ってください）--
// 例（メンバーで定義されていればこの部分はいりません）
//
// typedef struct {
